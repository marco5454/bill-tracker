# Bill & Credit Tracker — environment configuration
#
# Copy to `.env` (gitignored) and adjust as needed. None of these are secrets;
# the app has no auth and stores no credentials.

# API listen port. Default: 3000.
PORT=3000

# Bind address. Default: 127.0.0.1 (loopback only).
# Setting this to a non-loopback address ALSO requires BILLTRACKER_ALLOW_NETWORK=1
# below — the app will refuse to start otherwise, since it has no authentication.
HOST=127.0.0.1

# Required to be set to "1" before binding to a non-loopback HOST. Acknowledges
# that you are exposing an unauthenticated CRUD API to your network.
# BILLTRACKER_ALLOW_NETWORK=1

# Comma-separated allow-list of Host header values to accept (DNS rebinding
# defense). Default covers localhost / 127.0.0.1 / ::1 with and without :PORT.
# Add hostnames here when the operator gives the host a custom DNS name.
# BILLTRACKER_HOST_ALLOWLIST=billtracker.local,billtracker.local:3000

# When binding to the LAN (HOST=0.0.0.0 + BILLTRACKER_ALLOW_NETWORK=1) the
# unauthenticated /api/* endpoints stay loopback-only by default. Phones on
# the LAN can still load the static PWA shell; their service worker caches it
# and the in-app health probe returns 403, so the client transparently falls
# back to its IndexedDB local store. Set this to "1" only on a trusted LAN
# where you actually want LAN clients to share the server's database.
# BILLTRACKER_API_LAN=1

# 'production' makes the API also serve the built dist/ directory.
NODE_ENV=development

# Logger threshold: debug | info | warn | error | silent. Default: info.
# BILLTRACKER_LOG_LEVEL=info

# Override SQLite data directory (used by the test harness for isolation).
# BILLTRACKER_DATA_DIR=

# Disable the on-startup DB snapshot in data/backups/. Tests set this
# automatically. Useful when the data directory lives on a slow / size-capped
# volume where backups are managed externally.
# BILLTRACKER_DISABLE_BACKUPS=1

# Trust proxy setting for Express (used to derive req.ip). Default: off.
# Only enable this when an actual reverse proxy fronts the server, otherwise
# any local process can spoof X-Forwarded-For and bypass per-IP rate limits.
# Accepts an Express trust-proxy value: 'loopback', a specific IP, etc.
# BILLTRACKER_TRUST_PROXY=loopback

# How long the server waits for in-flight requests during graceful shutdown
# before force-closing remaining sockets. Milliseconds. Default: 10000.
# SHUTDOWN_TIMEOUT_MS=10000
