{
  "name": "billtracker",
  "version": "1.0.0",
  "description": "Bill & Credit Tracker - local web app with Node.js + SQLite backend",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.js",
    "test": "NODE_ENV=test node --test tests/",
    "audit": "npm audit --omit=dev",
    "install:desktop": "bash scripts/install-desktop.sh",
    "uninstall:desktop": "bash scripts/install-desktop.sh --remove"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "better-sqlite3": "^11.3.0",
    "compression": "^1.7.4",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "vite": "^6.4.3"
  },
  "overrides": {
    "shell-quote": "^1.8.4"
  },
  "engines": {
    "node": ">=18.19"
  }
}
